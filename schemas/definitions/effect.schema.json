{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lane-relay.local/schemas/definitions/effect.schema.json",
  "title": "Effect",
  "type": "object",
  "required": ["type", "target", "power"],
  "additionalProperties": false,
  "properties": {
    "type": {
      "type": "string",
      "enum": ["damage", "heal", "gain_mana", "draw_card"]
    },
    "target": {
      "type": "string",
      "enum": ["self", "enemy"]
    },
    "power": {
      "type": "integer",
      "minimum": 0
    },
    "scope": {
      "type": "string",
      "enum": ["local", "adjacent", "global"]
    },
    "damage_type": {
      "type": "string",
      "enum": ["physical", "magic", "true"]
    },
    "base_damage": {
      "type": "integer",
      "minimum": 0
    },
    "scaling": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stat", "ratio_bp"],
        "additionalProperties": false,
        "properties": {
          "stat": {
            "type": "string",
            "enum": ["ad", "ap", "max_hp", "current_hp", "missing_hp"]
          },
          "ratio_bp": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}
