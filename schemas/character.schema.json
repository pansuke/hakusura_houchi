{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lane-relay.local/schemas/character.schema.json",
  "title": "CharacterMaster",
  "type": "object",
  "required": ["id", "name", "resources", "action_resources", "combat_stats", "trait_ids"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^character_[a-z0-9_]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "resources": {
      "type": "object",
      "required": ["max_hp", "max_mp", "initial_mp"],
      "additionalProperties": false,
      "properties": {
        "max_hp": { "type": "integer", "minimum": 1 },
        "max_mp": { "type": "integer", "minimum": 0 },
        "initial_mp": { "type": "integer", "minimum": 0 }
      }
    },
    "action_resources": {
      "type": "object",
      "required": ["ds", "mpr", "hpr"],
      "additionalProperties": false,
      "properties": {
        "ds": { "type": "integer", "minimum": 0 },
        "mpr": { "type": "integer", "minimum": 0 },
        "hpr": { "type": "integer", "minimum": 0 }
      }
    },
    "combat_stats": {
      "type": "object",
      "required": ["ad", "ap", "ar", "mr", "push"],
      "additionalProperties": false,
      "properties": {
        "ad": { "type": "integer", "minimum": 0 },
        "ap": { "type": "integer", "minimum": 0 },
        "ar": { "type": "integer", "minimum": 0 },
        "mr": { "type": "integer", "minimum": 0 },
        "push": { "type": "integer", "minimum": 0 }
      }
    },
    "trait_ids": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    }
  }
}
