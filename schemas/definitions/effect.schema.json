{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lane-relay.local/schemas/definitions/effect.schema.json",
  "title": "Effect",
  "type": "object",
  "required": ["type", "target", "power"],
  "additionalProperties": false,
  "properties": {
    "type": {
      "type": "string",
      "enum": ["damage", "heal", "gain_mana", "draw_card"]
    },
    "target": {
      "type": "string",
      "enum": ["self", "enemy"]
    },
    "power": {
      "type": "integer",
      "minimum": 0
    }
  }
}
